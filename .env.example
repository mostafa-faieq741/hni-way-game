# ─────────────────────────────────────────────────────────────────────────────
# HNI Learning Object – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (gitignored) and fill in your values.
# NEVER commit real credentials to version control.
#
# Deployment: set these in your Vercel or Netlify dashboard under
# Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Google Sheets API (server-side only, never exposed to the browser) ────────

# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=

# Service account email from Google Cloud Console → IAM → Service Accounts.
# This account must have "Editor" access to the Google Sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the service account JSON file.
# Replace literal newlines with \n so the value fits on one line.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvAIB...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=


# ── TalentLMS API (server-side only) ──────────────────────────────────────────

# Your TalentLMS subdomain, e.g. yourcompany.talentlms.com
TALENTLMS_DOMAIN=

# TalentLMS REST API key (found in Admin → Security → API Key)
TALENTLMS_API_KEY=


# ── Frontend / Vite variables (prefixed VITE_ – visible to the browser) ───────

# Set to "true" in .env.development to enable mock SCORM identity.
# In production this must be "false" or absent.
VITE_DEV_MOCK_SCORM=true
